{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income, expense, savings)",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense", "savings"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "amount", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "User budget settings",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["user_id", "type", "amount"]
    },
    "Setting": {
      "title": "Setting",
      "description": "User specific settings",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["user_id", "key", "value"]
    },
    "RecurringPayment": {
      "title": "Recurring Payment",
      "description": "A recurring bill or payment",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "due_day": { "type": "number" }
      },
      "required": ["user_id", "name", "amount", "due_day"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions"
    },
    "budgets/{budgetId}": {
      "schema": { "$ref": "#/entities/Budget" },
      "description": "Budgets"
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Settings"
    },
    "recurring_payments/{paymentId}": {
      "schema": { "$ref": "#/entities/RecurringPayment" },
      "description": "Recurring payments"
    }
  }
}
